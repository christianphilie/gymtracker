{
  "compilerOptions": {
    "composite": true,
    "target": "ES2021",
    "lib": ["ES2021", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "include": [
    "vite.config.ts",
    "api/**/*.ts",
    "src/db/types.ts",
    "src/lib/muscle-taxonomy.ts",
    "src/lib/exercise-catalog.ts",
    "src/lib/workout-icons.ts",
    "src/features/import/import-utils.ts"
  ]
}
